#!/bin/bash
# Create LLApp lla
# Creates a boilerplate LLApp.lla metadata file inside each selected folder
# and opens it immediately in the LLStore metadata editor.
# The AppPath, Title, and desktop entry name are derived from the folder name.
# Spaces in the folder name are replaced with dots for the AppPath.

for folder in "$@"; do
    [ -d "$folder" ] || continue

    FOLDER_NAME="$(basename "$folder")"
    FOLDER_DOTS="${FOLDER_NAME// /.}"
    TODAY="$(date +%Y-%m-%d)"
    OUT="$folder/LLApp.lla"

    cat > "$OUT" << EOF
[LLFile]
Title=$FOLDER_NAME
Version=v1.01
Description=
URL=
Category=
BuildType=LLApp
AppPath=%LLApps%/$FOLDER_DOTS
Priority=5
DECompatible=All-Linux
PMCompatible=All
ArchCompatible=x86 + x64
[Meta]
InstalledSize=
Publisher=
Rating=
Players=1
ReleaseDate=$TODAY
License=1
[$FOLDER_NAME.desktop]
Exec=%AppPath%/run.sh
Comment=
Path=%AppPath%
Icon=%AppPath%/LLApp.png
Terminal=False
EOF

    echo "Created: $OUT"
    /opt/LastOS/LLStore/llstore -e "$OUT"
done
